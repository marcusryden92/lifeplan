model SimpleEvent {
  id              String              @id @default(cuid())
  title           String
  start           String
  end             String
  duration        Int?
  userId          String
  rrule           String?
  backgroundColor String
  borderColor     String
  createdAt       String
  updatedAt       String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  extendedProps   EventExtendedProps?

  @@map("SimpleEvents")
}

model EventExtendedProps {
  id                 String       @id @default(cuid())
  plannerType        PlannerType?
  eventType          EventType
  completedStartTime String?
  completedEndTime   String?
  parentId           String?
  eventId            String       @unique
  event              SimpleEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("EventExtendedProps")
}

model Planner {
  id                 String      @id @default(uuid())
  title              String
  parentId           String?
  plannerType        PlannerType
  isReady            Boolean?
  duration           Int
  deadline           String?
  starts             String?
  dependency         String?
  completedStartTime String?
  completedEndTime   String?
  priority           Int
  userId             String
  color              String?
  locationId         String? // Optional FK to Location (null = "Anywhere")
  useParentLocation  Boolean     @default(false) // When true, use category location instead of item's own locationId
  categoryId         String? // Optional FK to Category for organization
  createdAt          String
  updatedAt          String
  user               User        @relation(fields: [userId], references: [id])
  location           Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  category           Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("Planners")
}

model EventTemplate {
  id         String      @id @default(cuid())
  title      String
  startDay   WeekDayType
  startTime  String
  userId     String
  duration   Int
  color      String?
  locationId String? // Optional FK to Location (null = "Anywhere")
  createdAt  String
  updatedAt  String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@map("EventTemplates")
}

enum WeekDayType {
  sunday
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum PlannerType {
  task
  plan
  goal
}

enum EventType {
  planner
  template
  travel
  category
}

model Category {
  id        String  @id @default(uuid())
  name      String
  icon      String? // Emoji or icon identifier
  color     String? // Hex color for visual distinction
  sortOrder Int     @default(0)

  timeSlots CategoryTimeWindow[]

  // When false, the category is used purely for classification — its time windows
  // (if any) are ignored by the scheduler and items in it schedule freely.
  useTimeWindows Boolean @default(true)

  // Strict mode: when true, only items from this category can be in these time slots
  // When false, other items can fill empty space in the time slots
  isStrict Boolean @default(false)

  // Optional location for this category (items without location inherit this)
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Self-referential hierarchy (subcategories)
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")

  // User ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Items in this category (back-reference)
  planners Planner[]

  createdAt String @default(dbgenerated("NOW()::text"))
  updatedAt String

  @@map("Categories")
}

model CategoryTimeWindow {
  id        String @id @default(uuid())
  // Day of the week this window applies to (0=Sunday ... 6=Saturday, matches JS Date.getDay()).
  // One row per weekly occurrence: a Mon/Wed/Fri pattern is three rows.
  day       Int
  startTime String // HH:MM (24-hour)
  endTime   String // HH:MM (24-hour); if <= startTime the slot spans midnight

  // categoryId is nullable so the user can place windows on the calendar before
  // deciding which category they belong to (drafted, unassigned windows).
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // userId is the direct owner. Required so unassigned windows (categoryId=null)
  // are still scoped to a user.
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("CategoryTimeWindows")
}

// Location and Travel Time models for geographical scheduling

model Location {
  id        String   @id @default(cuid())
  name      String // User-friendly name: "Home", "Office", etc.
  address   String // Full formatted address from Google Places
  placeId   String // Google Place ID for reference
  lat       Float // Latitude
  lng       Float // Longitude
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations to travel times (this location as origin or destination)
  travelTimesFrom TravelTime[] @relation("FromLocation")
  travelTimesTo   TravelTime[] @relation("ToLocation")

  // Planners assigned to this location
  planners Planner[]

  // Templates assigned to this location
  templates EventTemplate[]

  // Categories assigned to this location
  categories Category[]

  @@unique([userId, placeId]) // Prevent duplicate locations per user
  @@map("Locations")
}

model TravelTime {
  id             String        @id @default(cuid())
  fromLocationId String
  toLocationId   String
  transportMode  TransportMode

  // Google API fetched values (baseline) - stored permanently
  googleRushHourMinutes Int // 7-9 AM, 5-7 PM weekdays
  googleRegularMinutes  Int // Other daytime hours
  googleNightMinutes    Int // 9 PM - 6 AM

  // User overrides (null = use Google value)
  customRushHourMinutes Int?
  customRegularMinutes  Int?
  customNightMinutes    Int?

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id], onDelete: Cascade)

  // Note: No self-referential entries (fromLocationId != toLocationId enforced in application code)
  @@unique([fromLocationId, toLocationId, transportMode])
  @@map("TravelTimes")
}

enum TransportMode {
  DRIVING
  TRANSIT
  BICYCLING
  WALKING
}

// User-level scheduling preferences
model UserSchedulingPreferences {
  id                   String        @id @default(cuid())
  userId               String        @unique
  bufferTimeMinutes    Int           @default(10) // Minimum buffer time between scheduled items
  defaultTransportMode TransportMode @default(DRIVING) // Default transport mode for travel time calculations
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@map("UserSchedulingPreferences")
}

// Task/Habit preferences
model TaskPreferences {
  id                 String        @id @default(cuid())
  plannerId          String        @unique // Links to Planner table
  taskType           TaskTypeEnum?
  preferredDays      Int[] // [1,2,3] = Mon, Tue, Wed
  preferredStartTime String? // "09:00"
  preferredEndTime   String? // "12:00"
  avoidDays          Int[] // Days to avoid
  priority           PriorityLevel @default(MEDIUM)
  energyLevel        EnergyLevel?
  allowFlexibility   Boolean       @default(true)

  @@map("TaskPreferences")
}

enum TaskTypeEnum {
  EXERCISE
  DEEP_WORK
  ADMIN
  MEETING
  CREATIVE
  ROUTINE
  HABIT
  SOCIAL
}

enum PriorityLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EnergyLevel {
  LOW // Light tasks
  MEDIUM // Normal tasks
  HIGH // Deep work, exercise
}

model User {
  id                    String                 @id @default(cuid())
  name                  String?
  email                 String?                @unique
  emailVerified         DateTime?              @map("email_verified")
  image                 String?
  password              String?
  role                  UserRole               @default(USER)
  isTwoFactorEnabled    Boolean                @default(false)
  EventTemplate         EventTemplate[]
  Planner               Planner[]
  SimpleEvent           SimpleEvent[]
  twoFactorConfirmation TwoFactorConfirmation?
  accounts              Account[]
  locations             Location[]
  categories            Category[]
  categoryTimeWindows   CategoryTimeWindow[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  ADMIN
  USER
}

generator client {
  provider = "prisma-client-js"
  output   = "../../lib/generated/db-client"
}

datasource db {
  provider = "postgresql"
}
