model SimpleEvent {
  id              String              @id @default(cuid())
  title           String
  start           String
  end             String
  duration        Int?
  userId          String
  rrule           String?
  backgroundColor String
  borderColor     String
  createdAt       String
  updatedAt       String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  extendedProps   EventExtendedProps?

  @@index([userId])
  @@map("SimpleEvents")
}

model EventExtendedProps {
  id                 String       @id @default(cuid())
  plannerType        PlannerType?
  eventType          EventType
  completedStartTime String?
  completedEndTime   String?
  parentId           String?
  eventId            String       @unique
  event              SimpleEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("EventExtendedProps")
}

model Planner {
  id                 String      @id @default(uuid())
  title              String
  parentId           String?
  plannerType        PlannerType
  isReady            Boolean?
  isTriaged          Boolean     @default(false) // Cleared on capture; set on first Capture save so the item leaves the triage queue
  duration           Int
  deadline           String?
  starts             String?
  recurrence           String? // JSON PlanRecurrenceRule ({freq, interval, until}); plans only — non-null makes the plan recurring, anchored on starts
  recurrenceExceptions String? // JSON PlanOccurrenceException[]; per-occurrence moved/deleted overrides keyed by the occurrence's original local start
  splitting            String? // JSON TaskSplittingSettings ({minMinutes, maxMinutes, maxMinutesPerDay?, minSpacingMinutes?}); tasks only — non-null makes the engine place the item as dynamically sized chunks
  completedSegments    String? // JSON CompletedSegment[] ({start, end}); one entry per completed chunk of a split task — completed minutes are always derived by summing, never stored
  maxMinutesPerDay     Int? // Goals only — max minutes of this goal's subtree the engine may place on any single day
  earliestStartDate    String? // Tasks + goals — the engine never places the item (or its subtree) before this instant; inherits down the tree as the max over ancestors
  allowedTimes         String? // JSON AllowedTimesSettings ({days, ranges}); tasks + goals — restricts dynamic placement to the given weekdays / time-of-day ranges, intersected down the tree
  linkedItemId         String? // Detour: on a subtask placeholder, points to a root goal/task whose leaves the engine splices in at this position (the placeholder's own duration/children are ignored while set). SetNull on target delete.
  notes                String? // Free-form user notes; never read by the engine
  sortOrder          Float       @default(0) // Fractional key ordering siblings within a parentId group; 0 on top-level roots (order non-semantic)
  completedStartTime String?
  completedEndTime   String?
  priority           Int
  userId             String
  color              String?
  locationId         String? // Optional FK to Location (null = "Anywhere")
  useParentLocation  Boolean     @default(false) // When true, use category location instead of item's own locationId
  categoryId         String? // Optional FK to Category for organization
  createdAt          String
  updatedAt          String
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location           Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)
  category           Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  linkedItem         Planner?    @relation("PlannerLink", fields: [linkedItemId], references: [id], onDelete: SetNull)
  linkedBy           Planner[]   @relation("PlannerLink")
  taskPreferences    TaskPreferences?
  queueMember        QueueMember?
  dependenciesAsPredecessor PlannerDependency[] @relation("DependencyPredecessor")
  dependenciesAsSuccessor   PlannerDependency[] @relation("DependencySuccessor")

  @@index([userId])
  @@map("Planners")
}

model EventTemplate {
  id                   String      @id @default(cuid())
  title                String
  startDay             WeekDayType
  startTime            String
  userId               String
  duration             Int
  color                String?
  locationId           String? // Optional FK to Location (null = "Anywhere")
  recurrenceExceptions String? // JSON PlanOccurrenceException[]; per-occurrence moved/deleted overrides keyed by the occurrence's original local start
  createdAt            String
  updatedAt            String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("EventTemplates")
}

enum WeekDayType {
  sunday
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum PlannerType {
  task
  plan
  goal
}

enum EventType {
  planner
  template
  travel
  category
}
