model SimpleEvent {
  id              String              @id @default(cuid())
  title           String
  start           String
  end             String
  duration        Int?
  userId          String
  rrule           String?
  backgroundColor String
  borderColor     String
  createdAt       String
  updatedAt       String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  extendedProps   EventExtendedProps?

  @@map("SimpleEvents")
}

model EventExtendedProps {
  id                 String      @id @default(cuid())
  itemType           ItemType
  completedStartTime String?
  completedEndTime   String?
  parentId           String?
  eventId            String      @unique
  event              SimpleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("EventExtendedProps")
}

model Planner {
  id                 String    @id @default(uuid())
  title              String
  parentId           String?
  itemType           ItemType
  isReady            Boolean?
  duration           Int
  deadline           String?
  starts             String?
  dependency         String?
  completedStartTime String?
  completedEndTime   String?
  priority           Int
  userId             String
  color              String?
  locationId         String? // Optional FK to Location (null = "Anywhere")
  useParentLocation  Boolean   @default(false) // When true, use category location instead of item's own locationId
  categoryId         String? // Optional FK to Category for organization
  createdAt          String
  updatedAt          String
  user               User      @relation(fields: [userId], references: [id])
  location           Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("Planners")
}

model EventTemplate {
  id         String      @id @default(cuid())
  title      String
  startDay   WeekDayType
  startTime  String
  userId     String
  duration   Int
  color      String?
  locationId String? // Optional FK to Location (null = "Anywhere")
  createdAt  String
  updatedAt  String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@map("EventTemplates")
}

enum WeekDayType {
  sunday
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum ItemType {
  task
  plan
  goal
  template
}
