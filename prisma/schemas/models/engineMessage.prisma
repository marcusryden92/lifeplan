// Engine-emitted messages surfaced in the calendar's engine console.
// Rows are engine-derived: on each regen the engine emits a fresh array
// consulting the previous array to carry forward the user-owned `dismissed`
// flag; the diff sync applies creates/updates/deletes against the
// deterministic id (see MESSAGE_ID_DELIM in
// utils/calendar-generation/models/EngineMessage.ts).
//
// Identity model: the id itself captures both "same recurring source" (so
// the engine emits one row per unique instance rather than spamming the
// console) and "same specific instance" (so dismissal survives regens as
// long as the id matches). Any change to a discriminating field (placement
// shift, new reason, new travel numbers) produces a new id → surfaces as a
// new row.

model EngineMessage {
  id String @id

  // Discriminator matching EngineMessageType in the app layer
  // ("TASK_TOO_LARGE" | "TASK_UNSCHEDULABLE" | "SCHEDULED_LATE" |
  // "INSUFFICIENT_TRAVEL" | ...).
  type String

  // "fail" | "warn" | "info"
  tone String

  // Type-specific structured payload. Kept as Json because the field set
  // differs per type and would balloon the schema; relational integrity for
  // referenced planners / travel events falls out of the regen sweep (a
  // deleted entity is no longer emitted → its row is diffed away).
  payload Json

  // User-owned soft-dismiss flag. Set by the dismiss button; carried forward
  // by the engine at emit time so a subsequent regen with the same id keeps
  // the row hidden. Cycling falls out naturally: when the engine stops
  // emitting a row the diff destroys it, and any later re-emit is a fresh
  // row with dismissed=false.
  dismissed Boolean @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt String @default(dbgenerated("NOW()::text"))
  updatedAt String

  @@index([userId])
  @@map("EngineMessages")
}
