// AI-assistant chat conversations. The id is client-minted (uuid on the
// first message of a fresh chat); messages is the whole ordered array as
// Json — conversations are only ever read and written wholesale, never
// queried per-message.
model DraftConversation {
  id       String @id
  title    String
  messages Json

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt String @default(dbgenerated("(now())::text"))
  updatedAt String

  @@index([userId])
  @@map("DraftConversations")
}
