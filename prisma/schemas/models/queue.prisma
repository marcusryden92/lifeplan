model Queue {
  id        String @id @default(uuid())
  title     String
  sortOrder Int    @default(0)

  // Optional inherited default: members with no effective category of their
  // own resolve to this at engine time (windows/strictness/location follow).
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  members QueueMember[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt String @default(dbgenerated("(now())::text"))
  updatedAt String

  @@index([userId])
  @@map("Queues")
}

model QueueMember {
  id        String @id @default(uuid())
  // Fractional sibling key within the queue (sortOrderKeys pattern) — a drag
  // rewrites one row.
  sortOrder Float  @default(0)

  queueId String
  queue   Queue  @relation(fields: [queueId], references: [id], onDelete: Cascade)

  // The unique IS the one-queue-per-planner invariant.
  plannerId String  @unique
  planner   Planner @relation(fields: [plannerId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt String @default(dbgenerated("(now())::text"))
  updatedAt String

  @@index([userId])
  @@map("QueueMembers")
}
