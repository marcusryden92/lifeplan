// Location and Travel Time models for geographical scheduling

model Location {
  id        String   @id @default(cuid())
  name      String   // User-friendly name: "Home", "Office", etc.
  address   String   // Full formatted address from Google Places
  placeId   String   // Google Place ID for reference
  lat       Float    // Latitude
  lng       Float    // Longitude
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations to travel times (this location as origin or destination)
  travelTimesFrom TravelTime[] @relation("FromLocation")
  travelTimesTo   TravelTime[] @relation("ToLocation")

  // Materialized travel events going from / to this location
  travelEventsFrom TravelEvent[] @relation("TravelEventFrom")
  travelEventsTo   TravelEvent[] @relation("TravelEventTo")

  // Planners assigned to this location
  planners Planner[]

  // Templates assigned to this location
  templates EventTemplate[]

  // Categories assigned to this location
  categories Category[]

  @@unique([userId, placeId]) // Prevent duplicate locations per user
  @@map("Locations")
}

model TravelTime {
  id             String        @id @default(cuid())
  fromLocationId String
  toLocationId   String
  transportMode  TransportMode

  // Google API fetched values (baseline) - stored permanently
  googleRushHourMinutes Int // 7-9 AM, 5-7 PM weekdays
  googleRegularMinutes  Int // Other daytime hours
  googleNightMinutes    Int // 9 PM - 6 AM

  // User overrides (null = use Google value)
  customRushHourMinutes Int?
  customRegularMinutes  Int?
  customNightMinutes    Int?

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromLocation Location @relation("FromLocation", fields: [fromLocationId], references: [id], onDelete: Cascade)
  toLocation   Location @relation("ToLocation", fields: [toLocationId], references: [id], onDelete: Cascade)

  // Note: No self-referential entries (fromLocationId != toLocationId enforced in application code)
  @@unique([fromLocationId, toLocationId, transportMode])
  @@map("TravelTimes")
}

enum TransportMode {
  DRIVING
  TRANSIT
  BICYCLING
  WALKING
}

model TravelEvent {
  // Deterministic id: `${fromLocationId ?? "anywhere"}-${toLocationId ?? "anywhere"}-${start}`.
  // Same logical travel at the same time produces the same row across regens
  // — sync becomes idempotent. Engine writes wholesale on each regen; the
  // diff lands as creates only when an actual placement shifted.
  id                    String    @id

  start                 String    // ISO datetime
  end                   String    // ISO datetime

  // Travel direction. Nullable when the engine couldn't determine a side
  // (e.g. start of day, no preceding event with a location).
  fromLocationId        String?
  fromLocation          Location? @relation("TravelEventFrom", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocationId          String?
  toLocation            Location? @relation("TravelEventTo", fields: [toLocationId], references: [id], onDelete: SetNull)

  // Engine's intended duration in minutes
  travelMinutes         Int
  // Originally-required minutes when the engine was forced into a smaller slot
  requiredTravelMinutes Int?

  // Visual markers — render red / yellow when set
  insufficientTravel    Boolean   @default(false)
  overconstrained       Boolean   @default(false)

  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             String    @default(dbgenerated("NOW()::text"))
  updatedAt             String

  @@map("TravelEvents")
}
