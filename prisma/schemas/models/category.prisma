model Category {
  id        String  @id @default(uuid())
  name      String
  icon      String? // Emoji or icon identifier
  color     String? // Hex color for visual distinction
  sortOrder Int     @default(0)

  timeSlots CategoryTimeWindow[]

  // When false, the category is used purely for classification â€” its time windows
  // (if any) are ignored by the scheduler and items in it schedule freely.
  useTimeWindows Boolean @default(true)

  // Strict mode: when true, only items from this category can be in these time slots
  // When false, other items can fill empty space in the time slots
  isStrict Boolean @default(false)

  // When true, items in this category schedule only in its own windows and never
  // cascade up into an ancestor category's windows. When false (default), a
  // subcategory's items are also eligible for its non-confined ancestors' windows
  // (a "project" item may use a "work" window). Also caps descendants: a confined
  // category is the ceiling for any descendant climbing the chain.
  confineToOwnWindows Boolean @default(false)

  // Optional location for this category (items without location inherit this)
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  // Self-referential hierarchy (subcategories)
  parentId String?
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")

  // User ownership
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Items in this category (back-reference)
  planners Planner[]

  // Materialized weekly occurrences with trespass info (back-reference)
  events CategoryEvent[]

  // Queues inheriting this category as their members' default (back-reference)
  queues Queue[]

  createdAt String @default(dbgenerated("(now())::text"))
  updatedAt String

  @@index([userId])
  @@map("Categories")
}

model CategoryTimeWindow {
  id        String @id @default(uuid())
  // Day of the week this window applies to (0=Sunday ... 6=Saturday, matches JS Date.getDay()).
  // One row per weekly occurrence: a Mon/Wed/Fri pattern is three rows.
  day       Int
  startTime String // HH:MM (24-hour)
  endTime   String // HH:MM (24-hour); if <= startTime the slot spans midnight

  // JSON PlanOccurrenceException[]; per-occurrence moved/deleted overrides
  // keyed by the occurrence's original local start
  recurrenceExceptions String?

  // categoryId is nullable so the user can place windows on the calendar before
  // deciding which category they belong to (drafted, unassigned windows).
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // userId is the direct owner. Required so unassigned windows (categoryId=null)
  // are still scoped to a user.
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Materialized weekly occurrences (back-reference). Cascade in CategoryEvent
  // ensures these go away when the window is deleted.
  events CategoryEvent[]

  @@index([userId])
  @@map("CategoryTimeWindows")
}

model CategoryEvent {
  // Deterministic id: `${categoryTimeWindowId}|${YYYY-MM-DD}` (local date key,
  // see buildCategoryEvents + the expansion-seam test). Same occurrence on
  // a regen produces the same row id, so sync sees no diff unless the slot
  // actually moved. No DB-side autogen needed.
  id String @id

  start String // ISO datetime
  end   String // ISO datetime

  // Trespass markers â€” engine fills these when its scheduling decisions
  // violated a category boundary. Renderer stamps red borders accordingly.
  trespassingStart Boolean @default(false)
  trespassingEnd   Boolean @default(false)

  // Source slot. Cascade so deleting a window deletes its materialized
  // occurrences.
  categoryTimeWindowId String
  categoryTimeWindow   CategoryTimeWindow @relation(fields: [categoryTimeWindowId], references: [id], onDelete: Cascade)

  // Owning category â€” required for render (color, name, isStrict).
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt String @default(dbgenerated("(now())::text"))
  updatedAt String

  @@index([userId])
  @@map("CategoryEvents")
}
