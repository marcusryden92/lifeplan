{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "@testing-library/jest-dom", "node"]
  },
  "include": ["__tests__/**/*.ts", "__tests__/**/*.tsx", "jest.setup.ts", "types/css.d.ts"],
  // The base config excludes __tests__ — without overriding exclude here the
  // inherited entry would win over include and this project would be empty.
  "exclude": ["node_modules"]
}
